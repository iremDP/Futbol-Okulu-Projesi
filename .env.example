# Futbol Okulu - Ortam Değişkenleri (Production için)
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin
# ÖNEMLİ: .env dosyasını asla Git'e eklemeyin! (.gitignore'da olmalı)

# JWT gizli anahtar - MUTLAKA değiştirin! (örn: openssl rand -base64 32)
# Production'da boş bırakırsanız uygulama başlamaz
JWT_SECRET=your-super-secret-key-change-this

# JWT token süresi (opsiyonel, varsayılan: 1d - XSS riskini azaltmak için kısaltıldı)
# JWT_EXPIRES=1d

# Port (varsayılan: 3000)
PORT=3000

# Production modu (hata mesajlarını gizler)
NODE_ENV=production

# CORS - İzin verilen origin'ler (virgülle ayırın)
# Production'da ZORUNLU! Örn: CORS_ORIGIN=https://sizin-domain.com,https://www.sizin-domain.com
CORS_ORIGIN=

# Veritabanı - Yüksek ölçek (on binlerce kayıt) için PostgreSQL kullanın
# Boş bırakırsanız SQLite kullanılır (geliştirme / küçük kurulumlar için)
# DATABASE_URL=postgresql://postgres:futbol2026@localhost:5432/futbol_okulu

# E-posta (Makbuz gönderimi için SMTP - varsa e-posta da gider)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Beşiktaş Futbol Okulu <your-email@gmail.com>

# SMS (Makbuz için NetGSM - telefon zorunlu, varsa SMS gider)
# NETGSM_USERCODE=your_usercode
# NETGSM_PASSWORD=your_password
# NETGSM_MSGHEADER=FUTBOL
