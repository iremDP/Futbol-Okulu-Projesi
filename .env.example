# Futbol Okulu - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın: copy .env.example .env
# ÖNEMLİ: .env dosyasını asla Git'e eklemeyin! (.gitignore'da olmalı)

# ========== ZORUNLU ==========
# JWT gizli anahtar - MUTLAKA değiştirin! (örn: openssl rand -base64 32)
# Production'da boş bırakırsanız uygulama başlamaz (en az 32 karakter)
JWT_SECRET=your-super-secret-key-change-this

# JWT süresi (varsayılan: 1d = 24 saat)
# JWT_EXPIRES=1d

# ========== VERİTABANI (PostgreSQL) ==========
# PostgreSQL için: Aşağıdaki satırı açın (başındaki # kaldırın) ve SIZIN_SIFRENIZ yerine
# PostgreSQL kurulumunda belirlediğiniz postgres şifresini yazın.
# Format: postgresql://KULLANICI:SIFRE@HOST:PORT/VERITABANI
# DATABASE_URL=postgresql://postgres:SIZIN_SIFRENIZ@localhost:5432/futbol_okulu

# Boş bırakırsanız SQLite kullanılır (futbol-okulu.db)
# PostgreSQL sorununda geçici SQLite: USE_SQLITE=true ekleyin

# ========== SUNUCU ==========
# Port (varsayılan: 3000)
PORT=3000

# Production modu (hata mesajlarını gizler)
# NODE_ENV=production

# CORS - İzin verilen origin'ler (virgülle ayırın)
# Production'da ZORUNLU! Örn: CORS_ORIGIN=https://sizin-domain.com
# CORS_ORIGIN=

# ========== E-POSTA (Opsiyonel) ==========
# Makbuz gönderimi için SMTP - varsa e-posta da gider
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Beşiktaş Futbol Okulu <your-email@gmail.com>

# SMS (Makbuz için NetGSM - telefon zorunlu, varsa SMS gider)
# NETGSM_USERCODE=your_usercode
# NETGSM_PASSWORD=your_password
# NETGSM_MSGHEADER=FUTBOL

# ========== LOGLAMA (Opsiyonel) ==========
# LOG_LEVEL=info (error, warn, info, debug)
# LOG_JSON=true (JSON formatında log - monitoring için)

# ========== TEST ==========
# Test çalıştırırken otomatik ayarlanır (npm test)
# NODE_ENV=test
# USE_SQLITE=true
