# Futbol Okulu - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın: copy .env.example .env
# ÖNEMLİ: .env dosyasını asla Git'e eklemeyin! (.gitignore'da olmalı)

# ========== ZORUNLU ==========
# JWT gizli anahtar - MUTLAKA değiştirin! (örn: openssl rand -base64 32)
# Production'da boş bırakırsanız uygulama başlamaz (en az 32 karakter)
JWT_SECRET=your-super-secret-key-change-this

# JWT süresi (varsayılan: 1d = 24 saat)
# JWT_EXPIRES=1d

# ========== VERİTABANI (PostgreSQL) ==========
# PostgreSQL için: Aşağıdaki satırı açın (başındaki # kaldırın) ve SIZIN_SIFRENIZ yerine
# PostgreSQL kurulumunda belirlediğiniz postgres şifresini yazın.
# Format: postgresql://KULLANICI:SIFRE@HOST:PORT/VERITABANI
# DATABASE_URL=postgresql://postgres:SIZIN_SIFRENIZ@localhost:5432/futbol_okulu

# Boş bırakırsanız SQLite kullanılır (futbol-okulu.db)
# PostgreSQL sorununda geçici SQLite: USE_SQLITE=true ekleyin

# ========== SUNUCU ==========
# Port (varsayılan: 3000)
PORT=3000

# Production modu (hata mesajlarını gizler) — canlı site için MUTLAKA: NODE_ENV=production
# NODE_ENV=production

# CORS - İzin verilen origin'ler (virgülle ayırın)
# Production'da ZORUNLU! Örn: CORS_ORIGIN=https://sizin-domain.com
# CORS_ORIGIN=

# İsteğe bağlı: Teknik teşhis için gizli anahtar (en az 16 karakter, örn: openssl rand -hex 24)
# Production'da /api/db-test bu anahtar olmadan kapanır.
# /api/health?db=1 ile kayıt sayıları sadece bu anahtarla görülür: ?key=SIZIN_ANAHTAR veya Authorization: Bearer SIZIN_ANAHTAR
# HEALTH_CHECK_SECRET=

# ========== E-POSTA (Opsiyonel) ==========
# Makbuz gönderimi için SMTP - varsa e-posta da gider
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Beşiktaş Futbol Okulu <your-email@gmail.com>

# SMS (Makbuz için NetGSM - telefon zorunlu, varsa SMS gider)
# NETGSM_USERCODE=your_usercode
# NETGSM_PASSWORD=your_password
# NETGSM_MSGHEADER=FUTBOL

# ========== WEB PUSH BİLDİRİMLERİ (Opsiyonel) ==========
# Anahtar üret: npm run push:keys — çıktıyı buraya yapıştırın.
# Boş bırakırsanız push bildirimleri devre dışı kalır; sistem sorunsuz çalışmaya devam eder.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@sizin-domain.com

# ========== WHATSAPP CLOUD API (Opsiyonel) ==========
# Meta WhatsApp Cloud API: https://developers.facebook.com/docs/whatsapp
# Yapılandırma yoksa otomatik WhatsApp kapalı kalır; sistem "wa.me" bağlantıları
# üretmeye (manuel tek tıkla gönderim) her zaman devam eder.
# WHATSAPP_API_TOKEN=          # Meta System User Access Token (uzun)
# WHATSAPP_PHONE_NUMBER_ID=    # Meta WhatsApp numarası ID (sayı)
# WHATSAPP_TEMPLATE_NAME=odeme_hatirlatma  # Meta'da onaylı utility template adı
# WHATSAPP_LANGUAGE_CODE=tr    # Template dili (varsayılan: tr)
# WHATSAPP_API_VERSION=v20.0   # Meta API sürümü (varsayılan: v20.0)
# WHATSAPP_USE_PLAIN=          # 1 yaparsanız template olmadan düz metin dener (sadece 24 saat penceresinde)

# ========== LOGLAMA (Opsiyonel) ==========
# LOG_LEVEL=info (error, warn, info, debug)
# LOG_JSON=true (JSON formatında log - monitoring için)

# ========== TEST ==========
# Test çalıştırırken otomatik ayarlanır (npm test)
# NODE_ENV=test
# USE_SQLITE=true
